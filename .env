SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,
# VPS: DEBUG=False, ALLOWED_HOSTS=104.236.1.98,...
# Production subpath (leave empty for local dev). Match Nginx location without trailing slash.
# FORCE_SCRIPT_NAME=/bulkgame
# CSRF when DEBUG=False: CSRF_TRUSTED_ORIGINS=http://104.236.1.98
# DATABASE_URL=postgres://user:pass@127.0.0.1:5432/bulkdel
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://127.0.0.1:8000/channels/facebook/callback/
# On VPS with subpath, e.g. http://104.236.1.98/bulkgame/channels/facebook/callback/
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
