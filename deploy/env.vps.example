# Copy to project root as .env on the VPS (adjust values).
# Full steps: deploy/VPS.md

SECRET_KEY=generate-a-long-random-string
DEBUG=False

# Comma-separated, no spaces. Include server IP if you browse by IP.
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,127.0.0.1,YOUR_SERVER_IP

# Required when DEBUG=False (include scheme). After SSL: https://...
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- URL layout ---
# Subdomain / own vhost at root (e.g. fbtools.site.com): leave empty or omit
# FORCE_SCRIPT_NAME=
# Site only under https://ip/bulkgame/: set FORCE_SCRIPT_NAME=/bulkgame (use nginx-vps-subpath / nginx-bulkgame.conf)
# FORCE_SCRIPT_NAME=/bulkgame

# --- Database (recommended on VPS) ---
# DATABASE_URL=postgres://USER:PASS@127.0.0.1:5432/bulkgame
# Or omit for SQLite (fine for small traffic; ensure www-data owns db.sqlite3)

# --- Redis + Celery (required for background FB deletes unless you use eager mode) ---
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
# Only if you do NOT run celery.service (not recommended on VPS):
# CELERY_TASK_ALWAYS_EAGER=True

# --- Facebook ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://yourdomain.com/channels/facebook/callback/
# If using subpath /bulkgame:
# FACEBOOK_REDIRECT_URI=https://yourdomain.com/bulkgame/channels/facebook/callback/

FERNET_KEY=
